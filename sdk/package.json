{
  "name": "@bifrost/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Bifrost RFQ protocol (bifrost/0.1) - pay any Lightning or Fiber invoice through Bifrost hubs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FadhilMulinya/bitfrost.git",
    "directory": "sdk"
  },
  "keywords": [
    "bifrost",
    "lightning",
    "fiber",
    "ckb",
    "bolt11",
    "htlc",
    "atomic-swap",
    "cross-chain"
  ],
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@scure/base": "^2.2.0",
    "light-bolt11-decoder": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
