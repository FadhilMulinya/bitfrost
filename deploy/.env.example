# Copy to deploy/.env — never commit the copy. Dev-only credentials.
# bitcoind regtest RPC (also injected into both LNDs as CLI flag overrides)
BITCOIN_RPC_USER=btc
BITCOIN_RPC_PASS=btc

# Passwords for the vendored fiber DEV secret keys (upstream test fixtures;
# these encrypt throwaway dev-chain keys, not real funds).
FNN_CLIENT_KEY_PASSWORD=password1
FNN_HUB_KEY_PASSWORD=password3

# fnn log filter
FNN_RUST_LOG=info,fnn=debug

# --- required by bifrostd/src/index.ts (bifrostd/src/config.ts validates these
#     at startup and refuses to start with a clear error if either is missing) ---

# The wBTC UDT's on-chain type-script code_hash. This repo runs against the
# LOCAL DEV CHAIN spun up by deploy/scripts (NOT public CKB testnet — see
# deploy/README.md for why we don't run against real testnet). The value
# below is the dev-chain fixture's code_hash, the same one printed by
# `deploy/scripts/smoke-cch.sh`'s wrapped_btc_type_script output and
# hardcoded in deploy/scripts/lib.sh / docker-compose.dev.yml. To point
# bifrostd at real CKB testnet or mainnet instead, replace this with that
# network's actual wBTC (or other UDT) type script code_hash — found via the
# UDT issuer's published script config or `ckb-cli` / a CKB explorer for the
# specific UDT you're wrapping.
UDT_CODE_HASH=0xe1e354d6d643ad42724d40967e334984534e0367405c5ae42a9d7d63d77df419

# The wBTC UDT type-script's args (identifies the specific UDT instance/owner
# lock under that code_hash). Same dev-chain-fixture caveat as UDT_CODE_HASH
# above — this is the local dev chain's value, also visible in
# smoke-cch.sh's wrapped_btc_type_script output. For testnet/mainnet, use
# that network's actual UDT args from the issuer's script config.
WBTC_ARGS=0x32e555f3ff8e135cece1351a6a2971518392c1e30375c1e006ad0ce8eac07947
