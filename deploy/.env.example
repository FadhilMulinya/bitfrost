# Copy to deploy/.env — never commit the copy. Dev-only credentials.
# bitcoind regtest RPC (also injected into both LNDs as CLI flag overrides)
BITCOIN_RPC_USER=btc
BITCOIN_RPC_PASS=btc

# Passwords for the vendored fiber DEV secret keys (upstream test fixtures;
# these encrypt throwaway dev-chain keys, not real funds).
FNN_CLIENT_KEY_PASSWORD=password1
FNN_HUB_KEY_PASSWORD=password3

# fnn log filter
FNN_RUST_LOG=info,fnn=debug

# --- required by bifrostd/src/index.ts (bifrostd/src/config.ts validates these
#     at startup and refuses to start with a clear error if either is missing) ---

# The wBTC UDT's on-chain type-script code_hash. This repo runs against the
# LOCAL DEV CHAIN spun up by deploy/scripts (NOT public CKB testnet — see
# deploy/README.md for why we don't run against real testnet). The value
# below is the dev-chain fixture's code_hash, the same one printed by
# `deploy/scripts/smoke-cch.sh`'s wrapped_btc_type_script output and
# hardcoded in deploy/scripts/lib.sh / docker-compose.dev.yml. To point
# bifrostd at real CKB testnet or mainnet instead, replace this with that
# network's actual wBTC (or other UDT) type script code_hash — found via the
# UDT issuer's published script config or `ckb-cli` / a CKB explorer for the
# specific UDT you're wrapping.
UDT_CODE_HASH=0xe1e354d6d643ad42724d40967e334984534e0367405c5ae42a9d7d63d77df419

# The wBTC UDT type-script's args (identifies the specific UDT instance/owner
# lock under that code_hash). Same dev-chain-fixture caveat as UDT_CODE_HASH
# above — this is the local dev chain's value, also visible in
# smoke-cch.sh's wrapped_btc_type_script output. For testnet/mainnet, use
# that network's actual UDT args from the issuer's script config.
WBTC_ARGS=0x32e555f3ff8e135cece1351a6a2971518392c1e30375c1e006ad0ce8eac07947

# ═══════════════════════════════════════════════════
# BIFROST HUB CONFIGURATION
# (bifrostd/src/config.ts — resolveHubConfig())
# ═══════════════════════════════════════════════════

# ── Hub identity ────────────────────────────────────
# Signing key for RFQ quotes (NOT a wallet key — never touches funds).
# Leave blank in HUB_MODE=dev to auto-generate an ephemeral key on every
# start (fine for local dev; quotes are self-verified against the pubkey
# embedded in the same response). Required for managed/external mode —
# generate one with: node scripts/generate-hub-key.mjs
# Back it up. If you lose it, clients with a pinned pubkey can't verify
# your quotes until they learn your new one.
HUB_SIGNING_KEY=

# ── Mode ────────────────────────────────────────────
# "dev"      → the docker-compose dev stack (default). LND and FNN are the
#              throwaway fixtures under deploy/vendor/; HUB_SIGNING_KEY may
#              be left blank.
# "managed"  → same node topology as dev, but for an operator's own
#              docker-compose-managed nodes; HUB_SIGNING_KEY is required.
# "external" → you run your own LND and FNN; bifrostd only calls their
#              standard RPC APIs and never touches wallet keys or seeds.
#              HUB_SIGNING_KEY, LND_MACAROON_PATH, LND_TLS_CERT_PATH,
#              UDT_CODE_HASH, and WBTC_ARGS are all required — no safe
#              defaults exist once real funds are involved. Also refuses to
#              start if DEMO_ENDPOINTS_ENABLED=true.
HUB_MODE=dev

# ── Lightning (LND) connection ───────────────────────
# Used to resolve the hub-side LND's REST base URL when LND_HUB_REST
# (the dev-stack override below, from docker-compose.dev.yml) isn't set.

LND_HOST=127.0.0.1
LND_REST_PORT=8080

# Path to your LND admin (or invoices+router-scoped) macaroon.
# Required for external mode; omit for a --no-macaroons dev node.
LND_MACAROON_PATH=

# Path to your LND node's TLS certificate. Required for external mode.
# bifrostd only checks this file is readable; the REST client trusts it via
# Node's NODE_EXTRA_CA_CERTS, not a per-request option — see
# bifrostd/src/adapters/transport.ts's LndRestOptions doc comment.
LND_TLS_CERT_PATH=

# Accepted for external-mode wallet-unlock docs but NOT YET WIRED — bifrostd
# does not currently call LND's wallet-unlock RPC. Unlock your LND wallet
# yourself before starting bifrostd if it doesn't auto-unlock. Tracked as a
# production gap in docs/STATUS.md.
LND_WALLET_PASSWORD=

# ── Fiber (FNN) connection ───────────────────────────
# bifrostd talks to an ALREADY-RUNNING FNN node over JSON-RPC/WS — it never
# starts FNN itself and never reads or holds the FNN node's private key.
# FNN_HOST/FNN_RPC_PORT are used to resolve the hub-side FNN's URL when
# FNN_HUB_URL/FNN_HUB_WS (the dev-stack overrides) aren't set.

FNN_HOST=127.0.0.1
FNN_RPC_PORT=21716

# ── Pricing ──────────────────────────────────────────
QUOTE_TTL_MS=30000
# HUB_FEE_PPM and QUOTE_STRATEGY are accepted for documentation but NOT YET
# WIRED into bifrostd/src/index.ts — the gateway currently hardcodes a 1:1,
# no-fee staticPeg strategy (see docs/STATUS.md's rfq/ row for the other
# strategies that exist and are tested but not yet selectable here).
HUB_FEE_PPM=2000
QUOTE_STRATEGY=static-peg
# Options: static-peg | feed-spread | inventory-skew

# ── Demo endpoints (dev only) ────────────────────────
# Set true ONLY for demos — allows unauthenticated invoice generation and
# simulated payments (docs/SECURITY.md Finding 3). NEVER true on mainnet;
# HUB_MODE=external refuses to start if this is true.
DEMO_ENDPOINTS_ENABLED=false
